// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  VENDOR
  ADMIN
}

enum ListingStatus {
  ACTIVE
  SOLD
  ARCHIVED
}

enum ListingCondition {
  NEW
  USED
}

enum NotificationType {
  MESSAGE
  LISTING
  SYSTEM
}

model User {
  id           String         @id @default(cuid())
  username     String         @unique
  email        String         @unique
  passwordHash String
  role         UserRole       @default(VENDOR)
  bannedAt     DateTime?
  banReason    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  vendor       Vendor?
  sessions     Session[]
  listings     Listing[]      @relation("ListingOwner")
  conversationsAsRequester Conversation[] @relation("RequesterConversations")
  conversationsAsOwner     Conversation[] @relation("OwnerConversations")
  messages     Message[]
  sentNotifications Notification[] @relation("NotificationSender")
  receivedNotifications Notification[] @relation("NotificationReceiver")
  reports     Report[]
  resolvedReports Report[] @relation("ReportResolver")
  reviewsGiven Review[] @relation("ReviewAuthor")
}

model Vendor {
  id           String   @id @default(cuid())
  userId       String   @unique
  storeName    String
  slug         String   @unique
  city         String?
  area         String?
  street       String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
  listings     Listing[]
  reviews      Review[]
}

model Listing {
  id          String            @id @default(cuid())
  vendorId    String
  ownerId     String
  title       String
  category    String
  subcategory String?
  description String?
  price       Decimal?          @db.Decimal(12, 2)
  condition   ListingCondition  @default(USED)
  status      ListingStatus     @default(ACTIVE)
  city        String
  area        String
  details     Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  vendor      Vendor            @relation(fields: [vendorId], references: [id])
  owner       User              @relation("ListingOwner", fields: [ownerId], references: [id])
  images      Image[]
  conversations Conversation[]
}

model Image {
  id        String   @id @default(cuid())
  listingId String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  listing   Listing  @relation(fields: [listingId], references: [id])
}

model Conversation {
  id         String   @id @default(cuid())
  listingId  String
  requesterId String
  ownerId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  listing    Listing  @relation(fields: [listingId], references: [id])
  requester  User     @relation("RequesterConversations", fields: [requesterId], references: [id])
  owner      User     @relation("OwnerConversations", fields: [ownerId], references: [id])
  messages   Message[]
  notifications Notification[] @relation("ConversationNotifications")

  @@unique([listingId, requesterId, ownerId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime      @default(now())
  readAt         DateTime?

  conversation   Conversation  @relation(fields: [conversationId], references: [id])
  sender         User          @relation(fields: [senderId], references: [id])
}

model Notification {
  id        String            @id @default(cuid())
  senderId  String
  receiverId String
  conversationId String?
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime          @default(now())

  sender    User              @relation("NotificationSender", fields: [senderId], references: [id])
  receiver  User              @relation("NotificationReceiver", fields: [receiverId], references: [id])
  conversation Conversation?  @relation("ConversationNotifications", fields: [conversationId], references: [id])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  targetType String
  targetId   String
  reason     String
  resolvedAt DateTime?
  resolvedById String?
  createdAt  DateTime @default(now())

  reporter   User     @relation(fields: [reporterId], references: [id])
  resolvedBy User?    @relation("ReportResolver", fields: [resolvedById], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  vendorId   String
  reviewerId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  vendor     Vendor   @relation(fields: [vendorId], references: [id])
  reviewer   User     @relation("ReviewAuthor", fields: [reviewerId], references: [id])

  @@unique([vendorId, reviewerId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
