// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  VENDOR
  ADMIN
}

enum VerificationStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum ListingStatus {
  ACTIVE
  SOLD
  ARCHIVED
}

enum ListingModerationState {
  PENDING
  APPROVED
  REJECTED
}

enum ListingCondition {
  NEW
  USED
}

enum NotificationType {
  MESSAGE
  LISTING
  SYSTEM
}

enum FeedbackType {
  BUG
  FEATURE
  GENERAL
}

model User {
  id           String         @id @default(cuid())
  username     String         @unique
  email        String         @unique
  passwordHash String
  role         UserRole       @default(VENDOR)
  bannedAt     DateTime?
  banReason    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  vendor       Vendor?
  sessions     Session[]
  passwordResetTokens PasswordResetToken[]
  uploads      Upload[]
  savedListings SavedListing[]
  listings     Listing[]      @relation("ListingOwner")
  conversationsAsRequester Conversation[] @relation("RequesterConversations")
  conversationsAsOwner     Conversation[] @relation("OwnerConversations")
  messages     Message[]
  sentNotifications Notification[] @relation("NotificationSender")
  receivedNotifications Notification[] @relation("NotificationReceiver")
  reports     Report[]
  resolvedReports Report[] @relation("ReportResolver")
  reviewsGiven Review[] @relation("ReviewAuthor")
  savedSearches SavedSearch[]
  analyticsEvents AnalyticsEvent[]
  fraudSignals FraudSignal[] @relation("FraudSignalActor")
  resolvedFraudSignals FraudSignal[] @relation("FraudSignalResolver")
  adminAuditLogs AdminAuditLog[] @relation("AdminAuditActor")
  feedbackEntries Feedback[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Vendor {
  id           String   @id @default(cuid())
  userId       String   @unique
  storeName    String
  slug         String   @unique
  city         String?
  area         String?
  street       String?
  phone        String?
  profileImageUploadId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
  profileImageUpload Upload? @relation("VendorProfileImage", fields: [profileImageUploadId], references: [id])
  uploads      Upload[]
  listings     Listing[]
  reviews      Review[]
  phoneVerificationStatus VerificationStatus @default(NONE)
  idVerificationStatus VerificationStatus @default(NONE)
  addressVerificationStatus VerificationStatus @default(NONE)
  trustScore Int @default(0)
  verificationSubmittedAt DateTime?
  verificationReviewedAt DateTime?
  verificationNotes String?
}

model Listing {
  id          String            @id @default(cuid())
  vendorId    String
  ownerId     String
  title       String
  category    String
  subcategory String?
  description String?
  price       Decimal?          @db.Decimal(12, 2)
  condition   ListingCondition  @default(USED)
  status      ListingStatus     @default(ACTIVE)
  moderationState ListingModerationState @default(APPROVED)
  moderationReason String?
  moderatedAt DateTime?
  moderatedByUserId String?
  expiresAt   DateTime?
  city        String
  area        String
  details     Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  vendor      Vendor            @relation(fields: [vendorId], references: [id])
  owner       User              @relation("ListingOwner", fields: [ownerId], references: [id])
  images      Image[]
  conversations Conversation[]
  savedByUsers SavedListing[]

  @@index([status, createdAt])
  @@index([moderationState, status, createdAt])
  @@index([expiresAt, status])
  @@index([status, moderationState, expiresAt, createdAt])
  @@index([vendorId, createdAt])
  @@index([ownerId, createdAt])
  @@index([ownerId, category, title, createdAt])
  @@index([category, subcategory])
}

model RateLimitBucket {
  key         String   @id
  count       Int
  windowStart DateTime
  updatedAt   DateTime @updatedAt
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId, createdAt])
}

model Image {
  id        String   @id @default(cuid())
  listingId String
  uploadId  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  listing   Listing  @relation(fields: [listingId], references: [id])
  upload    Upload   @relation(fields: [uploadId], references: [id])

  @@index([listingId, sortOrder])
}

model Upload {
  id               String   @id @default(cuid())
  ownerUserId      String
  ownerVendorId    String?
  path             String
  mimeType         String
  size             Int
  linkedEntityType String?
  linkedEntityId   String?
  createdAt        DateTime @default(now())

  ownerUser        User     @relation(fields: [ownerUserId], references: [id])
  ownerVendor      Vendor?  @relation(fields: [ownerVendorId], references: [id])
  listingImages    Image[]
  vendorProfileOf  Vendor[] @relation("VendorProfileImage")

  @@index([ownerUserId])
  @@index([ownerVendorId])
  @@index([linkedEntityType, linkedEntityId])
}

model Conversation {
  id         String   @id @default(cuid())
  listingId  String
  requesterId String
  ownerId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  listing    Listing  @relation(fields: [listingId], references: [id])
  requester  User     @relation("RequesterConversations", fields: [requesterId], references: [id])
  owner      User     @relation("OwnerConversations", fields: [ownerId], references: [id])
  messages   Message[]
  notifications Notification[] @relation("ConversationNotifications")

  @@unique([listingId, requesterId, ownerId])
  @@index([requesterId, updatedAt])
  @@index([ownerId, updatedAt])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime      @default(now())
  readAt         DateTime?
  seenAt         DateTime?

  conversation   Conversation  @relation(fields: [conversationId], references: [id])
  sender         User          @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
  @@index([conversationId, seenAt])
  @@index([conversationId, senderId, readAt])
}

model Feedback {
  id        String       @id @default(cuid())
  userId    String?
  type      FeedbackType @default(GENERAL)
  message   String
  createdAt DateTime     @default(now())

  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId, createdAt])
}

model Notification {
  id        String            @id @default(cuid())
  senderId  String
  receiverId String
  conversationId String?
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime          @default(now())

  sender    User              @relation("NotificationSender", fields: [senderId], references: [id])
  receiver  User              @relation("NotificationReceiver", fields: [receiverId], references: [id])
  conversation Conversation?  @relation("ConversationNotifications", fields: [conversationId], references: [id])

  @@index([receiverId, readAt, type, createdAt])
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  query     Json
  isActive  Boolean  @default(true)
  lastNotifiedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive, updatedAt])
}

model FraudSignal {
  id        String   @id @default(cuid())
  userId    String
  type      String
  severity  Int      @default(1)
  notes     String?
  data      Json?
  resolvedAt DateTime?
  resolvedById String?
  resolutionNote String?
  createdAt DateTime @default(now())

  user      User     @relation("FraudSignalActor", fields: [userId], references: [id], onDelete: Cascade)
  resolvedBy User?   @relation("FraudSignalResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([userId, type, createdAt])
  @@index([severity, createdAt])
  @@index([resolvedAt, createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventName String
  page      String?
  referrer  String?
  data      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([userId, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actor       User     @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  targetType String
  targetId   String
  reason     String
  resolvedAt DateTime?
  resolvedById String?
  createdAt  DateTime @default(now())

  reporter   User     @relation(fields: [reporterId], references: [id])
  resolvedBy User?    @relation("ReportResolver", fields: [resolvedById], references: [id])

  @@index([createdAt])
}

model Review {
  id         String   @id @default(cuid())
  vendorId   String
  reviewerId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  vendor     Vendor   @relation(fields: [vendorId], references: [id])
  reviewer   User     @relation("ReviewAuthor", fields: [reviewerId], references: [id])

  @@unique([vendorId, reviewerId])
  @@index([vendorId, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}
