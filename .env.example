# Copy to `.env` (local) or set these in your host’s environment (production).
# Never commit real passwords.

# MySQL — used by Prisma (see prisma/schema.prisma)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Yegara / cPanel: create DB + user in “MySQL Databases”, then use the host they show
# (often localhost if the app runs on the same server, or a hostname like mysql.yourdomain.com).
#
# If the password contains @ # % / : etc., URL-encode them (e.g. @ → %40).
DATABASE_URL="mysql://db_user:db_password@localhost:3306/your_database_name"

# Optional: Node environment (hosting panels often set this automatically)
# NODE_ENV=production
