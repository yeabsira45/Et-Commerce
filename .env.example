# Copy to `.env` (local) or set these in your host’s environment (production).
# Never commit real passwords.

# MySQL — used by Prisma (see prisma/schema.prisma)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Yegara / cPanel: create DB + user in “MySQL Databases”, then use the host they show
# (often localhost if the app runs on the same server, or a hostname like mysql.yourdomain.com).
#
# If the password contains @ # % / : etc., URL-encode them (e.g. @ → %40).
DATABASE_URL="mysql://db_user:db_password@localhost:3306/your_database_name"

# Google OAuth (for Login / Signup with Google)
# Create OAuth Client ID in Google Cloud Console
# Authorized redirect URI example:
# http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Optional: if omitted, callback URL is derived automatically from request origin
# GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Optional: Node environment (hosting panels often set this automatically)
# NODE_ENV=production

# Email / SMTP (OTP password reset + notifications)
# For custom domain mailbox (recommended in production):
# EMAIL_HOST="smtp.your-provider.com"
# EMAIL_PORT="587"
# EMAIL_SECURE="false" # true for 465
# EMAIL_USER="hello@commerceet.com"
# EMAIL_PASS="your-mailbox-password-or-app-password"
#
# If EMAIL_HOST is not set, code falls back to Gmail service mode.

# Optional diagnostics
# LOG_SLOW_QUERIES="true"
# SLOW_QUERY_LOG_MS="400"
